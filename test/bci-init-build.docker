FROM registry.opensuse.org/opensuse/bci/bci-init:latest

RUN zypper install -y go git make systemd-devel

WORKDIR /src
ADD systemd-mcp.tar.gz .
RUN cd systemd-mcp && make build && make install
RUN cd systemd-mcp/testClient && go build -o /usr/local/bin/mcp-client main.go

# Add dummy service
RUN printf "[Unit]\nDescription=Dummy Service\n\n[Service]\nExecStart=/bin/sh -c 'while true; do echo \"Dummy log line at \$(date)\"; sleep 1; done'\n[Install]\nWantedBy=multi-user.target\n" > /etc/systemd/system/dummy.service
RUN systemctl enable dummy.service

# Add failed dummy service
RUN printf "[Unit]\nDescription=Failed Dummy Service\n\n[Service]\nType=oneshot\nExecStart=/usr/bin/false\n[Install]\nWantedBy=multi-user.target\n" > /etc/systemd/system/failed-dummy.service
RUN systemctl enable failed-dummy.service

# Add a non-root user for testing authorization failure
RUN groupadd -r systemd-journal
RUN useradd -m testuser && useradd -m -G systemd-journal loguser 

# The default ENTRYPOINT for bci-init is /usr/lib/systemd/systemd
